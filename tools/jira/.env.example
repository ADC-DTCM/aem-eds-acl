# Required ----------------------------------------------------------------

# Atlassian account email (used as the username for HTTP Basic auth).
USER_EMAIL=you@example.com

# Atlassian API token. Create one at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Atlassian Cloud base URL. No trailing slash, no /rest/... suffix.
ATLASSIAN_BASE_URL=https://yourorg.atlassian.net

# Target Jira project key (e.g. DOCEDS). The project must already exist.
JIRA_PROJECT_KEY=DOCEDS

# Optional ----------------------------------------------------------------

# Full Rovo agent invoke URL. If unset, refinement is skipped (script falls
# back to posting the stories as-authored).
# ROVO_AGENT_URL=https://api.atlassian.com/rovo/v1/agents/<agent-id>/invoke

# Optional Rovo agent identifier; included in the request body if set.
# ROVO_AGENT_ID=

# Issue type names (defaults shown). Override only if your project uses
# non-standard issue type names.
# JIRA_STORY_TYPE=Story
# JIRA_EPIC_TYPE=Epic

# Legacy company-managed projects may still require the Epic Link custom
# field (e.g. customfield_10014). When set, stories are linked to their
# parent epic via this field instead of the modern `parent` field.
# JIRA_EPIC_LINK_FIELD=

# Logging level: DEBUG, INFO, WARNING, ERROR. Default INFO.
# LOG_LEVEL=INFO
